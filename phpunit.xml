<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="SECRETS_KEY" value="base64:dGVzdGtleXRlc3RrZXl0ZXN0a2V5dGVzdGtleTEyMzQ="/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="INCOMING_MEDIA_DOWNLOAD" value="false"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="TENANCY_SINGLE_ACCOUNT_FALLBACK" value="true"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <!-- Fatia 26: Asaas FAKE na suite inteira - teste NUNCA enxerga chave real nem sai pra rede (Http::fake nos testes de checkout). -->
        <env name="ASAAS_API_KEY" value="chave-fake-de-teste"/>
        <env name="ASAAS_BASE_URL" value="https://api-sandbox.asaas.com"/>
        <env name="ASAAS_WEBHOOK_TOKEN" value="token-webhook-de-teste-0123456789abcdef"/>
        <!-- Servidores: canal DESLIGADO na suite por padrao (modo silencioso), independente
             do .env real (o dono ligou o flag em producao-DEV). Os testes de envio real
             sobrescrevem para true via config()->set no proprio teste (ServersCanalTest). -->
        <env name="SERVERS_NOTIFICATIONS_ENABLED" value="false"/>
    </php>
</phpunit>
